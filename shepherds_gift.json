{
  "type": "origins:action_on_entity_use",
  "name": "Shepherd's Gift",
  "description": "Interacting with sheep, cows, or chickens calls forth their gift without harming them. (5 minute cooldown)",
  "cooldown": 6000,
  "hud_render": {
    "should_render": false
  },
  "bientity_condition": {
    "type": "origins:target_condition",
    "condition": {
      "type": "origins:or",
      "conditions": [
        { "type": "origins:entity_type", "entity_type": "minecraft:sheep" },
        { "type": "origins:entity_type", "entity_type": "minecraft:cow" },
        { "type": "origins:entity_type", "entity_type": "minecraft:chicken" }
      ]
    }
  },
  "bientity_action": {
    "type": "origins:if_else",
    "condition": {
      "type": "origins:target_condition",
      "condition": { "type": "origins:entity_type", "entity_type": "minecraft:sheep" }
    },
    "then": {
      "type": "origins:actor_action",
      "action": {
        "type": "origins:give",
        "stack": { "item": "minecraft:white_wool", "amount": 1 }
      }
    },
    "else": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:target_condition",
        "condition": { "type": "origins:entity_type", "entity_type": "minecraft:cow" }
      },
      "then": {
        "type": "origins:actor_action",
        "action": {
          "type": "origins:give",
          "stack": { "item": "minecraft:leather", "amount": 1 }
        }
      },
      "else": {
        "type": "origins:if_else",
        "condition": {
          "type": "origins:target_condition",
          "condition": { "type": "origins:entity_type", "entity_type": "minecraft:chicken" }
        },
        "then": {
          "type": "origins:actor_action",
          "action": {
            "type": "origins:give",
            "stack": { "item": "minecraft:feather", "amount": 1 }
          }
        }
      }
    }
  }
}
