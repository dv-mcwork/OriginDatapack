{
  "type": "origins:active_self",
  "name": "Myceliumify",
  "description": "Hold to spread your fungal network through the earth, converting any block into mycelium. The longer you hold, the wider the spread: 3 blocks at 1 second, growing up to 15 blocks at 15 seconds.",
  "cooldown": 1,
  "key": {
    "key": "key.origins.primary_active",
    "continuous": true
  },
  "hud_render": {
    "should_render": false
  },
  "entity_action": {
    "type": "origins:if_else",
    "condition": {
      "type": "origins:resource",
      "resource": "origin_pack:myceliumify_cooldown",
      "comparison": "==",
      "compare_to": 0
    },
    "if_action": {
    "type": "origins:and",
    "actions": [
      {
        "type": "origins:change_resource",
        "resource": "origin_pack:spore_charge",
        "change": 3
      },
      {
        "type": "origins:if_else_list",
        "actions": [
          {
            "condition": {
              "type": "origins:resource",
              "resource": "origin_pack:spore_charge",
              "comparison": ">=",
              "compare_to": 300
            },
            "action": {
              "type": "origins:and",
              "actions": [
                {
                  "type": "origins:block_action_at",
                  "block_action": {
                    "type": "origins:area_of_effect",
                    "radius": 15,
                    "shape": "sphere",
                    "block_action": {
                      "type": "origins:set_block",
                      "block": "minecraft:mycelium"
                    },
                    "block_condition": {
                      "type": "origins:or",
                      "conditions": [
                        { "type": "origins:block", "block": "minecraft:air" },
                        { "type": "origins:block", "block": "minecraft:bedrock" },
                        { "type": "origins:block", "block": "minecraft:mycelium" }
                      ],
                      "inverted": true
                    }
                  }
                },
                {
                  "type": "origins:spawn_particles",
                  "particle": { "type": "minecraft:block", "params": "minecraft:mycelium" },
                  "count": 40,
                  "speed": 0.0,
                  "force": true,
                  "spread": { "x": 15.0, "y": 0.1, "z": 15.0 }
                },
                {
                  "type": "origins:change_resource",
                  "resource": "origin_pack:spore_charge",
                  "change": -300
                },
                {
                  "type": "origins:trigger_cooldown",
                  "power": "origin_pack:myceliumify_cooldown"
                }
              ]
            }
          },
          {
            "condition": {
              "type": "origins:resource",
              "resource": "origin_pack:spore_charge",
              "comparison": ">=",
              "compare_to": 100
            },
            "action": {
              "type": "origins:and",
              "actions": [
                {
                  "type": "origins:block_action_at",
                  "block_action": {
                    "type": "origins:area_of_effect",
                    "radius": 9,
                    "shape": "sphere",
                    "block_action": {
                      "type": "origins:set_block",
                      "block": "minecraft:mycelium"
                    },
                    "block_condition": {
                      "type": "origins:or",
                      "conditions": [
                        { "type": "origins:block", "block": "minecraft:air" },
                        { "type": "origins:block", "block": "minecraft:bedrock" },
                        { "type": "origins:block", "block": "minecraft:mycelium" }
                      ],
                      "inverted": true
                    }
                  }
                },
                {
                  "type": "origins:spawn_particles",
                  "particle": { "type": "minecraft:block", "params": "minecraft:mycelium" },
                  "count": 24,
                  "speed": 0.0,
                  "force": true,
                  "spread": { "x": 9.0, "y": 0.1, "z": 9.0 }
                }
              ]
            }
          },
          {
            "condition": {
              "type": "origins:resource",
              "resource": "origin_pack:spore_charge",
              "comparison": ">=",
              "compare_to": 20
            },
            "action": {
              "type": "origins:and",
              "actions": [
                {
                  "type": "origins:block_action_at",
                  "block_action": {
                    "type": "origins:area_of_effect",
                    "radius": 3,
                    "shape": "sphere",
                    "block_action": {
                      "type": "origins:set_block",
                      "block": "minecraft:mycelium"
                    },
                    "block_condition": {
                      "type": "origins:or",
                      "conditions": [
                        { "type": "origins:block", "block": "minecraft:air" },
                        { "type": "origins:block", "block": "minecraft:bedrock" },
                        { "type": "origins:block", "block": "minecraft:mycelium" }
                      ],
                      "inverted": true
                    }
                  }
                },
                {
                  "type": "origins:spawn_particles",
                  "particle": { "type": "minecraft:block", "params": "minecraft:mycelium" },
                  "count": 10,
                  "speed": 0.0,
                  "force": true,
                  "spread": { "x": 3.0, "y": 0.1, "z": 3.0 }
                }
              ]
            }
          }
        ]
      }
    ]
    }
  }
}
