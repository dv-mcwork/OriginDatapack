{
  "type": "origins:action_on_hit",
  "name": "Chilling Touch",
  "description": "Your touch saps warmth from anything you strike, inflicting Slowness II on them, unless you are standing on ice or snow.",
  "cooldown": 1,
  "hud_render": {
    "should_render": false
  },
  "bientity_action": {
    "type": "origins:target_action",
    "action": {
      "type": "origins:apply_effect",
      "effect": {
        "effect": "minecraft:slowness",
        "amplifier": 1,
        "duration": 100
      }
    }
  },
  "bientity_condition": {
    "type": "origins:actor_condition",
    "condition": {
      "type": "origins:on_block",
      "block_condition": {
        "type": "origins:or",
        "conditions": [
          { "type": "origins:block", "block": "minecraft:ice" },
          { "type": "origins:block", "block": "minecraft:packed_ice" },
          { "type": "origins:block", "block": "minecraft:blue_ice" },
          { "type": "origins:block", "block": "minecraft:frosted_ice" },
          { "type": "origins:block", "block": "minecraft:snow" },
          { "type": "origins:block", "block": "minecraft:snow_block" },
          { "type": "origins:block", "block": "minecraft:powder_snow" }
        ]
      },
      "inverted": true
    }
  }
}
